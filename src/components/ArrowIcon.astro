---
/**
 * Directional stroke arrow. Rendered as SVG, never a text glyph, so it stays
 * crisp at any size and inherits `currentColor`.
 */
interface Props {
  direction: "up-right" | "left" | "up";
  size?: number;
}

const { direction, size = 13 } = Astro.props;

const paths = {
  "up-right": "M3 11 L11 3 M4.5 3 H11 V9.5",
  left: "M12 7 H2.5 M6.5 2.5 L2 7 L6.5 11.5",
  up: "M7 12 V2.5 M2.5 6.5 L7 2 L11.5 6.5",
} as const;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 14 14"
  fill="none"
  aria-hidden="true"
>
  <path d={paths[direction]} stroke="currentColor" stroke-width="2.4"></path>
</svg>
