---
import ArrowIcon from "./ArrowIcon.astro";

/**
 * Link styled as a button. Labels arrive already-cased from i18n/data, so the
 * component never forces uppercase (domain labels like "ai-mods.de" stay lowercase).
 */
interface Props {
  href: string;
  variant: "filled-light" | "outline" | "accent-outline" | "accent-filled";
  external?: boolean;
  arrow?: boolean;
}

const { href, variant, external = false, arrow = false } = Astro.props;

const rel = external ? "noopener" : undefined;
const target = external ? "_blank" : undefined;

// Arrow size follows the button size (spec §3).
const arrowSize = {
  "accent-outline": 11,
  outline: 13,
  "filled-light": 13,
  "accent-filled": 14,
}[variant];
---

<a href={href} target={target} rel={rel} class:list={["btn", variant]}>
  <slot />
  {arrow && <ArrowIcon direction="up-right" size={arrowSize} />}
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
  }

  /* Optically lift the arrow to the text center. */
  .btn :global(svg) {
    margin-top: -2px;
  }

  .filled-light {
    background: var(--text);
    color: var(--acc-ink);
    padding: 17px 28px 15px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.05em;
    gap: 8px;
  }

  .outline {
    background: transparent;
    border: 1px solid var(--border-btn);
    color: var(--text);
    padding: 17px 28px 15px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.05em;
    gap: 8px;
  }

  .accent-outline {
    border: 2px solid var(--acc);
    color: var(--acc);
    padding: 10px 18px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11.5px;
    letter-spacing: 0.08em;
    gap: 7px;
  }

  .accent-outline:hover {
    background: var(--acc);
    color: var(--acc-ink);
  }

  .accent-filled {
    background: var(--acc);
    color: var(--acc-ink);
    padding: 19px 36px 17px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 15px;
    line-height: 1;
    letter-spacing: 0.04em;
    gap: 9px;
  }
</style>
