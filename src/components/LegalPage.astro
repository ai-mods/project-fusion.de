---
import { useTranslations, type Lang } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";
import BackLink from "./BackLink.astro";
import Kicker from "./Kicker.astro";
import ToTopButton from "./ToTopButton.astro";

/**
 * Privacy-policy page shell (§8): chrome (header, kicker, H1, updated line,
 * footer) around the language-specific sections, which the route files pass
 * in via the slot. `alternatePath` wires canonical/hreflang and the language
 * switch to the counterpart route in the other language.
 */
interface Props {
  lang: Lang;
  alternatePath: string;
}

const { lang, alternatePath } = Astro.props;
const t = useTranslations(lang);

const title = t("legal.title");
const description = t("legal.description");
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  alternatePath={alternatePath}
>
  <SiteHeader lang={lang} alternatePath={alternatePath} />

  <main class="legal">
    <div class="inner">
      <BackLink lang={lang} />

      <Kicker>{t("legal.kicker")}</Kicker>

      {
        /* No space before the span: DE breaks after the hyphen
           ("DATENSCHUTZ-ERKLÄRUNG"), EN carries the space in the key. */
      }
      <h1 class="title">
        {t("legal.h1a")}<span class="outline">{t("legal.h1b")}</span>
      </h1>

      <div class="updated">{t("legal.updated")}</div>

      <slot />
    </div>

    <ToTopButton lang={lang} />
  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

<style>
  .legal {
    padding: 64px var(--pad-x) 100px;
  }

  .inner {
    max-width: var(--maxw-legal);
    margin-inline: auto;
  }

  .legal :global(.kicker) {
    margin-bottom: 20px;
  }

  .title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(34px, 6vw, 56px);
    line-height: 1;
    text-transform: uppercase;
  }

  .outline {
    color: transparent;
    -webkit-text-stroke: 2px var(--acc);
  }

  .updated {
    margin: 14px 0 56px;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-ghost);
  }

  /* Spec §9: large H1 stroke one step thinner below 640px (2 → 1.5). */
  @media (max-width: 640px) {
    .outline {
      -webkit-text-stroke-width: 1.5px;
    }
  }
</style>
