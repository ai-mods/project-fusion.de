---
import { modules } from "../data/modules";
import { useTranslations, type Lang } from "../i18n/utils";
import Kicker from "./Kicker.astro";
import SectionHeading from "./SectionHeading.astro";

/**
 * "Core Modules" grid (§6.5). Cells sit on a 1px hairline via the gap technique
 * (grid gap + background), so column reflow needs no per-cell border rules.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="modules" class="modules">
  <div class="inner">
    <Kicker>{t("modules.kicker")}</Kicker>
    <SectionHeading
      lines={[
        { text: t("modules.h2a") },
        { text: t("modules.h2b"), outline: true },
      ]}
    />
    <p class="sub">{t("modules.sub")}</p>

    <div class="grid">
      {
        modules.map((module) => (
          <div class="cell">
            <div class="number">{module.number}</div>
            <div class="title">{module.title}</div>
            <p class="desc">{module.description[lang]}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .modules {
    padding: 80px var(--pad-x);
  }

  .inner {
    max-width: var(--maxw);
    margin-inline: auto;
  }

  .modules :global(.kicker) {
    margin-bottom: 16px;
  }

  .modules :global(.heading) {
    margin-bottom: 12px;
  }

  .sub {
    margin: 0 0 40px;
    max-width: 520px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-dim);
  }

  /* Gap technique: 1px gaps on a hairline background create the dividers (§6.5). */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hairline-color);
    border: 1px solid var(--hairline-color);
  }

  .cell {
    background: var(--bg);
    padding: 26px;
    transition: background-color 150ms ease;
  }

  .cell:hover {
    background: var(--surface-hover);
  }

  .number {
    margin-bottom: 14px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    color: var(--acc);
  }

  .title {
    margin-bottom: 10px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-dim);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
