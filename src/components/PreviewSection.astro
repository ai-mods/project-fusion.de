---
import { Image } from "astro:assets";
import { tabs } from "../data/tabs";
import { useTranslations, type Lang } from "../i18n/utils";
import Kicker from "./Kicker.astro";

/**
 * "App Preview" tab switcher (§6.6). Eight screenshot tabs; a small vanilla
 * script (no framework) drives selection, roving tabindex and arrow-key nav.
 * The H2 is local because its outline word sits inline (SectionHeading breaks
 * each line), not on its own line.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="preview" class="preview">
  <div class="inner">
    <Kicker>{t("preview.kicker")}</Kicker>
    <h2 class="heading">
      {/* Explicit space: Astro trims the line break before the span. */}
      {t("preview.h2a")}{" "}
      <span class="outline">{t("preview.h2b")}</span>
    </h2>
    <p class="sub">{t("preview.sub")}</p>

    <div class="tablist" role="tablist" aria-label={t("preview.kicker")}>
      {
        tabs.map((tab, i) => (
          <button
            id={`tab-${tab.id}`}
            class:list={["tab", { active: i === 0 }]}
            role="tab"
            type="button"
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`panel-${tab.id}`}
            tabindex={i === 0 ? 0 : -1}
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    {
      tabs.map((tab, i) => (
        <div
          id={`panel-${tab.id}`}
          class="panel"
          role="tabpanel"
          aria-labelledby={`tab-${tab.id}`}
          tabindex="0"
          hidden={i !== 0}
        >
          <Image
            src={tab.image}
            alt={t("a11y.screenshotAlt").replace("{tab}", tab.label)}
            widths={[640, 1000, 1500, 2000]}
            sizes="(max-width: 1072px) 100vw, 1000px"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))
    }
  </div>
</section>

<script>
  const list = document.querySelector<HTMLElement>('[role="tablist"]');

  if (list) {
    const tabs = Array.from(
      list.querySelectorAll<HTMLButtonElement>('[role="tab"]'),
    );

    const select = (tab: HTMLButtonElement) => {
      tabs.forEach((other) => {
        const selected = other === tab;
        other.setAttribute("aria-selected", selected ? "true" : "false");
        other.classList.toggle("active", selected);
        other.tabIndex = selected ? 0 : -1;

        const panel = document.getElementById(
          other.getAttribute("aria-controls") ?? "",
        );
        if (panel) panel.hidden = !selected;
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => select(tab));

      tab.addEventListener("keydown", (event) => {
        if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
        event.preventDefault();
        const step = event.key === "ArrowRight" ? 1 : -1;
        const next = tabs[(index + step + tabs.length) % tabs.length];
        select(next);
        next.focus();
      });
    });
  }
</script>

<style>
  .preview {
    padding: 40px var(--pad-x) 80px;
    text-align: center;
  }

  .inner {
    max-width: var(--maxw);
    margin-inline: auto;
  }

  .preview :global(.kicker) {
    margin-bottom: 16px;
  }

  .heading {
    margin: 0 0 32px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(36px, 5.5vw, 64px);
    line-height: 1;
    text-transform: uppercase;
  }

  .outline {
    color: transparent;
    -webkit-text-stroke: 2px var(--acc);
  }

  .sub {
    margin: 0 auto 32px;
    max-width: 460px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-dim);
  }

  .tablist {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px;
    border-bottom: var(--hairline);
    margin-bottom: 32px;
  }

  .tab {
    padding: 12px 4px;
    margin-bottom: -1px;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    cursor: pointer;
  }

  .tab.active {
    color: var(--acc);
    border-bottom-color: var(--acc);
  }

  .panel {
    max-width: 1000px;
    margin-inline: auto;
    border: 1px solid var(--border-img);
  }

  .panel :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 640px) {
    .outline {
      -webkit-text-stroke-width: 1.5px;
    }
  }
</style>
