---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Language-specific legal routes, linked directly in the footer so the
// imprint is easily recognizable and directly reachable (German § 5 DDG).
const privacyPath = lang === "de" ? "/de/datenschutz/" : "/privacy/";
const imprintPath = lang === "de" ? "/de/impressum/" : "/imprint/";
---

<footer class="footer">
  <div class="inner">
    <span>
      {t("footer.copyright")}<span class="suffix"
        >{t("footer.copyrightSuffix")}</span
      >
    </span>
    <div class="links">
      <a href={privacyPath}>{t("footer.privacy")}</a>
      <a href={imprintPath}>{t("footer.imprint")}</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 20px var(--pad-x);
    border-top: var(--hairline);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-ghost);
  }

  .inner {
    display: flex;
    justify-content: space-between;
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .links {
    display: flex;
    gap: 20px;
  }

  .links a:hover {
    color: var(--acc);
  }

  /* Phones show only "© 2026 AI-MODS"; the project name is too much there. */
  @media (max-width: 640px) {
    .suffix {
      display: none;
    }
  }
</style>
